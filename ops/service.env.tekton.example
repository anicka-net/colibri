# Colibri service environment — discrete multi-GPU host ("profile A" in the
# hardware-tuning skill).  Reference machine: 2x H100 NVL + 2x 64-core EPYC,
# model on tmpfs.  Copy to ~/.config/colibri/service.env and edit.
#
# See ops/README.md for the install steps and docs/ENVIRONMENT.md for every
# variable.  Numbers below are measured on that reference machine.

# ---- what to serve -------------------------------------------------------
COLI_MODEL=/home/colibri/tmpfs/GLM-5.2-colibri-int4
COLI_HOST=127.0.0.1
COLI_PORT=8000
COLI_MODEL_ID=deepseek-v4-flash
COLI_CORS_ORIGIN=http://localhost:5173

# Context: 32768 is the largest VALIDATED end-to-end setting (26.8k-token
# prompt, zero fallbacks).  The attention paths themselves run to 131072, but
# prefill scratch grows with PROMPT length (q/ctx staging is S*H*qh*4 bytes,
# ~8.6 GB each at 131k) and lands on the same GPUs as the expert tier — going
# past ~64k means lowering CUDA_EXPERT_GB.  Raise deliberately, then watch
# nvidia-smi during a full-length prompt.
COLI_CONTEXT=32768
COLI_MAX_TOKENS=16384
COLI_KV_SLOTS=1
COLI_CAP=256
COLI_EXPERT_BITS=4
COLI_DENSE_BITS=4

# ---- engine profile A ----------------------------------------------------
COLI_CUDA=1
COLI_GPUS=0,1
CUDA_DENSE=1
# Total across GPUs; leave 3-9 GB per card for dense weights, KV shadows and
# scratch.  150 GB is the measured knee at CTX<=32768.
CUDA_EXPERT_GB=150
COLI_CUDA_PIPE=2
COLI_CUDA_PIPE_S_MIN=1
# Lossless-weight tensor-core path; engages at rows>=16 (prefill), never decode.
COLI_CUDA_TC_W4A16=1
# Model is RAM-resident on tmpfs: there is no NVMe path to protect.
DIRECT=0
# NOTE: do NOT set AUTOPIN=0 here (the unified-memory example does, where it is
# right).  On this profile the startup pin pass is what fills the VRAM expert
# tier from .coli_usage — with it disabled the tier stays empty, every routed
# expert is served from RAM, and decode drops from ~19 to ~1.7 tok/s while
# nvidia-smi shows a few hundred MB instead of CUDA_EXPERT_GB.
# Physical cores (not SMT threads).
OMP_NUM_THREADS=128
OMP_PLACES=cores
OMP_PROC_BIND=spread
# MTP: ~91% acceptance but roughly break-even at short context and only
# +4-5% end-to-end with DSA; keep drafts off until small-S forwards get cheaper.
DRAFT=0

# The HTTP server needs Python >= 3.7 (ThreadingHTTPServer).  Set this when the
# distro's default python3 is older — SLES 15 ships 3.6, which dies 100 ms into
# startup with an ImportError.  The unit invokes this interpreter explicitly.
COLI_PYTHON=/usr/bin/python3.13

# ---- preflight guards (ops/colibri-preflight.sh) -------------------------
# tmpfs does NOT survive a reboot: without these the service would start
# against an empty/half-copied snapshot and Restart=always would spin.
COLI_PREFLIGHT_MIN_SHARDS=141
COLI_PREFLIGHT_MIN_GB=340
# The indexer files enable DSA sparse attention (the long-context win).
COLI_PREFLIGHT_NEED_IDX=1
# CUDA on the open kernel module needs nvidia_uvm loaded with
# uvm_disable_hmm=1, otherwise every CUDA call fails with error 3 and no
# diagnostics (open-gpu-kernel-modules #780/#797).
COLI_PREFLIGHT_UVM_HMM=1
